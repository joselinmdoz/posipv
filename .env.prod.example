# =============================================================================
# Variables de entorno - PRODUCCION (Docker Compose)
# Copiar como .env.prod y ajustar valores
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_POR_UNA_MUY_SEGURA

# JWT (minimo 32+ caracteres aleatorios)
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_LARGO_Y_ALEATORIO

# Origenes permitidos por CORS (separados por coma)
# Ejemplo con dominio publico:
# CORS_ORIGIN=https://pos.tudominio.com
CORS_ORIGIN=http://localhost,http://127.0.0.1

# Admin inicial (seed)
SEED_ADMIN_EMAIL=admin@pos.local
SEED_ADMIN_PASSWORD=Admin123!
