generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IPVType {
  INITIAL
  FINAL
}

enum Role {
  ADMIN
  CASHIER
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum SaleStatus {
  PAID
  VOID
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  VOID
}

enum SaleChannel {
  TPV
  DIRECT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum CurrencyCode {
  CUP
  USD
}

enum AccountingAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum JournalLineSide {
  DEBIT
  CREDIT
}

enum AccountingPostingRuleKey {
  SALE_REVENUE_CUP
  SALE_REVENUE_USD
  SALE_COGS
  STOCK_IN
  STOCK_OUT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CASHIER)
  permissions  String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  cashSessions CashSession[]
  sales        Sale[]
  employee     Employee?
  journalEntriesCreated JournalEntry[] @relation("JournalEntryCreatedBy")
  journalEntriesPosted  JournalEntry[] @relation("JournalEntryPostedBy")
  periodsClosed         FiscalPeriod[] @relation("FiscalPeriodClosedBy")
  purchasesCreated      Purchase[]     @relation("PurchaseCreatedBy")
}

model Employee {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  identification String?  @unique
  phone          String?
  email          String?
  position       String?
  hireDate       DateTime?
  salary         Decimal? @db.Decimal(12,2)
  image          String?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])

  @@index([firstName, lastName])
  @@index([active])
}

model Register {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique @default(cuid())
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  cashSessions CashSession[]
  settings     RegisterSettings?
  warehouse    Warehouse?
}

model CashSession {
  id            String            @id @default(cuid())
  status        CashSessionStatus @default(OPEN)
  openedAt      DateTime          @default(now())
  closedAt      DateTime?
  openingAmount Decimal           @db.Decimal(12,2)
  closingAmount Decimal?          @db.Decimal(12,2)
  note          String?

  registerId String
  register   Register @relation(fields: [registerId], references: [id])

  openedById String
  openedBy   User     @relation(fields: [openedById], references: [id])

  sales              Sale[]
  inventoryReports   InventoryReport[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  codigo   String?  @unique
  barcode   String?  @unique
  price     Decimal  @db.Decimal(12,2)
  cost      Decimal? @db.Decimal(12,2)
  lowStockAlertQty Decimal? @db.Decimal(12,3)
  allowFractionalQty Boolean @default(false)
  currency  CurrencyCode @default(CUP)
  image     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  productTypeId     String?
  productType       ProductType?     @relation(fields: [productTypeId], references: [id])
  
  productCategoryId String?
  productCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])
  
  measurementUnitId String?
  measurementUnit   MeasurementUnit? @relation(fields: [measurementUnitId], references: [id])

  items                 SaleItem[]
  purchaseItems         PurchaseItem[]
  stock                 Stock[]
  stockMovements        StockMovement[]
  inventoryReportItems  InventoryReportItem[]
}

model Sale {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  status      SaleStatus @default(PAID)
  channel     SaleChannel @default(TPV)
  total       Decimal    @db.Decimal(12,2)
  customerId  String?
  customerName String?
  documentNumber String? @unique

  cashierId   String
  cashier     User       @relation(fields: [cashierId], references: [id])

  customer    Client?    @relation(fields: [customerId], references: [id])

  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  items     SaleItem[]
  payments  Payment[]
}

model Client {
  id             String   @id @default(cuid())
  name           String
  identification String   @unique
  phone          String?
  email          String?
  address        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales          Sale[]

  @@index([name])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  qty       Decimal  @db.Decimal(12,3)
  price     Decimal  @db.Decimal(12,2)
  costSnapshot Decimal? @db.Decimal(12,2)
}

model Purchase {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  confirmedAt     DateTime?
  voidedAt        DateTime?
  status          PurchaseStatus @default(CONFIRMED)
  documentNumber  String?        @unique
  supplierName    String?
  supplierDocument String?
  note            String?
  subtotal        Decimal        @db.Decimal(12,2)
  total           Decimal        @db.Decimal(12,2)
  currency        CurrencyCode   @default(CUP)

  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])

  createdById     String
  createdBy       User           @relation("PurchaseCreatedBy", fields: [createdById], references: [id])

  items           PurchaseItem[]

  @@index([warehouseId, createdAt])
  @@index([status, createdAt])
}

model PurchaseItem {
  id         String    @id @default(cuid())
  purchaseId String
  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId  String
  product    Product   @relation(fields: [productId], references: [id])

  qty        Decimal   @db.Decimal(12,3)
  cost       Decimal   @db.Decimal(12,2)
  total      Decimal   @db.Decimal(12,2)

  @@index([purchaseId])
  @@index([productId])
}

model Payment {
  id       String        @id @default(cuid())
  saleId   String
  sale     Sale          @relation(fields: [saleId], references: [id])

  method   PaymentMethod
  amount   Decimal       @db.Decimal(12,2)
  currency CurrencyCode  @default(CUP)
  amountOriginal Decimal @db.Decimal(12,2)
  transactionCode String?
  exchangeRateUsdToCup Decimal? @db.Decimal(12,6)
  exchangeRateRecordId String?
  exchangeRateRecord ExchangeRateRecord? @relation(fields: [exchangeRateRecordId], references: [id])
}

enum WarehouseType {
  CENTRAL
  TPV
}

model Warehouse {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique
  type      WarehouseType  @default(TPV)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  registerId String?   @unique
  register   Register? @relation(fields: [registerId], references: [id])

  registerSettings RegisterSettings[]

  stock                 Stock[]
  fromMovements         StockMovement[] @relation("FromWarehouse")
  toMovements           StockMovement[] @relation("ToWarehouse")
  inventoryReports      InventoryReport[]
  sales                 Sale[]
  purchases             Purchase[]
}

model Stock {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  qty         Decimal  @db.Decimal(12,3) @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([warehouseId, productId])
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
}

model StockMovement {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  type            StockMovementType

  productId       String
  product         Product           @relation(fields: [productId], references: [id])

  qty             Decimal @db.Decimal(12,3)

  fromWarehouseId String?
  fromWarehouse   Warehouse?        @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])

  toWarehouseId   String?
  toWarehouse     Warehouse?        @relation("ToWarehouse", fields: [toWarehouseId], references: [id])

  reason          String?
}

model Denomination {
  id                String  @id @default(cuid())
  value             Decimal @db.Decimal(12,2)
  enabled           Boolean @default(true)
  currency          CurrencyCode @default(CUP)
  registerSettingsId String?
  registerSettings   RegisterSettings? @relation(fields: [registerSettingsId], references: [id])

  @@index([registerSettingsId, currency])
  @@unique([registerSettingsId, currency, value])
}

model PaymentMethodSetting {
  id                String  @id @default(cuid())
  code              String  @unique
  name              String
  enabled           Boolean @default(true)
  requiresTransactionCode Boolean @default(false)
  registerSettingsId String?
  registerSettings   RegisterSettings? @relation(fields: [registerSettingsId], references: [id])
}

model RegisterSettings {
  id                  String   @id @default(cuid())
  registerId          String   @unique
  register            Register @relation(fields: [registerId], references: [id])

  defaultOpeningFloat Decimal  @db.Decimal(12,2) @default(0)
  currency            String   @default("USD")
  warehouseId         String?
  sellerEmployeeIds   String[] @default([])
  warehouse           Warehouse? @relation(fields: [warehouseId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  paymentMethods PaymentMethodSetting[]
  denominations  Denomination[]
}

model SystemSettings {
  id                     String   @id
  defaultCurrency        CurrencyCode @default(CUP)
  enabledCurrencies      CurrencyCode[] @default([CUP, USD])
  exchangeRateUsdToCup   Decimal  @db.Decimal(12,6) @default(1)
  systemName             String   @default("POS System")
  systemLogoUrl          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SystemLicense {
  id              String    @id
  licenseData     String?
  payloadJson     Json?
  payloadHash     String?
  licenseId       String?   @unique
  deviceHash      String?
  issuedAt        DateTime?
  validFrom       DateTime?
  expiresAt       DateTime?
  features        String[]  @default([])
  maxUsers        Int?
  status          String    @default("MISSING")
  statusMessage   String?
  lastValidatedAt DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ExchangeRateRecord {
  id                   String       @id @default(cuid())
  baseCurrency         CurrencyCode @default(USD)
  quoteCurrency        CurrencyCode @default(CUP)
  rate                 Decimal      @db.Decimal(12,6)
  source               String?      @default("SYSTEM_SETTINGS")
  createdAt            DateTime     @default(now())

  payments             Payment[]
}

model InventoryReport {
  id          String   @id @default(cuid())
  type        IPVType
  createdAt   DateTime @default(now())
  totalValue  Decimal  @db.Decimal(12,2) @default(0)
  note        String?

  cashSessionId String
  cashSession   CashSession @relation(fields: [cashSessionId], references: [id])

  warehouseId String
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  items       InventoryReportItem[]
}

model InventoryReportItem {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id])

  qty       Decimal         @db.Decimal(12,3)
  price     Decimal         @db.Decimal(12,2)
  total     Decimal         @db.Decimal(12,2)

  inventoryReportId String
  inventoryReport   InventoryReport @relation(fields: [inventoryReportId], references: [id])
}

// Catálogos de productos
model ProductType {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  products Product[]
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  products Product[]
}

// Unidades de medida
model MeasurementUnitType {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  measurementUnits MeasurementUnit[]
}

model MeasurementUnit {
  id        String              @id @default(cuid())
  name      String
  symbol    String
  active    Boolean             @default(true)
  createdAt DateTime           @default(now())

  typeId    String?
  type      MeasurementUnitType? @relation(fields: [typeId], references: [id])

  products Product[]
}

model AccountingAccount {
  id                 String               @id @default(cuid())
  code               String               @unique
  name               String
  type               AccountingAccountType
  description        String?
  allowManualEntries Boolean              @default(true)
  active             Boolean              @default(true)
  parentId           String?
  parent             AccountingAccount?   @relation("AccountingAccountHierarchy", fields: [parentId], references: [id])
  children           AccountingAccount[]  @relation("AccountingAccountHierarchy")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  journalLines       JournalLine[]
  debitPostingRules  AccountingPostingRule[] @relation("PostingRuleDebitAccount")
  creditPostingRules AccountingPostingRule[] @relation("PostingRuleCreditAccount")

  @@index([type, active])
  @@index([parentId])
}

model AccountingPostingRule {
  id              String                   @id @default(cuid())
  key             AccountingPostingRuleKey @unique
  name            String
  description     String?
  active          Boolean                  @default(true)
  debitAccountId  String
  creditAccountId String
  debitAccount    AccountingAccount        @relation("PostingRuleDebitAccount", fields: [debitAccountId], references: [id])
  creditAccount   AccountingAccount        @relation("PostingRuleCreditAccount", fields: [creditAccountId], references: [id])
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([active, key])
}

model FiscalPeriod {
  id         String                @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     AccountingPeriodStatus @default(OPEN)
  closeNotes String?
  closedAt   DateTime?
  closedById String?
  closedBy   User?                 @relation("FiscalPeriodClosedBy", fields: [closedById], references: [id])
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  journalEntries JournalEntry[]

  @@unique([startDate, endDate])
  @@index([status, startDate, endDate])
}

model JournalEntry {
  id                   String            @id @default(cuid())
  entryNumber          String            @unique
  date                 DateTime          @default(now())
  description          String
  reference            String?
  status               JournalEntryStatus @default(POSTED)
  sourceType           String?
  sourceId             String?
  totalDebit           Decimal           @db.Decimal(14,2)
  totalCredit          Decimal           @db.Decimal(14,2)
  currency             CurrencyCode      @default(CUP)
  exchangeRateUsdToCup Decimal?          @db.Decimal(12,6)
  postedAt             DateTime?
  voidedAt             DateTime?
  voidReason           String?
  createdById          String
  createdBy            User              @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])
  postedById           String?
  postedBy             User?             @relation("JournalEntryPostedBy", fields: [postedById], references: [id])
  periodId             String?
  period               FiscalPeriod?     @relation(fields: [periodId], references: [id])
  lines                JournalLine[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([date, status])
  @@index([periodId])
  @@index([sourceType, sourceId])
  @@unique([sourceType, sourceId])
}

model JournalLine {
  id             String         @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        AccountingAccount @relation(fields: [accountId], references: [id])
  side           JournalLineSide
  amount         Decimal        @db.Decimal(14,2)
  memo           String?
  createdAt      DateTime       @default(now())

  @@index([journalEntryId])
  @@index([accountId, side])
}
